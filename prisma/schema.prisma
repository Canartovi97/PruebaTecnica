// Prisma schema
// Motor: SQLite para desarrollo local sin dependencias externas.
// En produccion, cambiar "provider" a "postgresql" y DATABASE_URL:
// el resto del modelo y del codigo de aplicacion no cambia.

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// SQLite no soporta el tipo `enum` nativo de Prisma (si se migra a
// PostgreSQL, estos campos String se pueden convertir a enum real).
// Los valores validos se definen y se tipan en src/common/enums.ts,
// y se validan en el limite HTTP con Zod (modules/*/*.dto.ts).

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      String // "CLIENT" | "PROVIDER"
  createdAt DateTime @default(now())

  requests ProductRequest[] @relation("ClientRequests")
  offers   Offer[]          @relation("ProviderOffers")
}

model ProductRequest {
  id          String        @id @default(uuid())
  clientId    String
  client      User          @relation("ClientRequests", fields: [clientId], references: [id])
  productName String
  description String?
  quantity    Int
  status      String   @default("OPEN") // "OPEN" | "IN_NEGOTIATION" | "CLOSED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offers Offer[]

  @@index([clientId])
  @@index([status])
}

model Offer {
  id         String      @id @default(uuid())
  requestId  String
  request    ProductRequest @relation(fields: [requestId], references: [id])
  providerId String
  provider   User        @relation("ProviderOffers", fields: [providerId], references: [id])
  price      Float
  message    String?
  status     String   @default("PENDING") // "PENDING" | "ACCEPTED" | "REJECTED" | "COUNTERED"
  createdAt  DateTime @default(now())

  @@index([requestId])
  @@index([providerId])
}
